def _echo_impl(ctx):
    # The output file is declared with a name based on the target's name.
    out_file = ctx.actions.declare_file("%s.txt" % ctx.attr.name)

    a = ""
    a = a*6

    ctx.actions.run_shell(
        inputs = [],
        outputs = [out_file],
        command = "set -euo pipefail; echo {} $1 > {}".format(a, out_file.path),
        arguments = ["arg"],
    )
    return [DefaultInfo(files = depset([out_file]))]

echo = rule(
    implementation = _echo_impl,
    attrs = {},
)
